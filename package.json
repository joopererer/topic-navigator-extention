{
  "name": "topic-navigator-extension",
  "version": "1.0.3",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --config vite.config.content.ts --watch",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "tsc --noEmit && vite build --config vite.config.content.ts && vite build --config vite.config.background.ts && vite build --config vite.config.popup.ts && vite build --config vite.config.options.ts",
    "build:firefox": "npm run build && node scripts/build-firefox.mjs",
    "package:release": "npm run build:firefox && node scripts/package-release.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.0",
    "archiver": "^7.0.1",
    "jsdom": "^25.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^8.0.10",
    "vitest": "^2.1.8"
  }
}
